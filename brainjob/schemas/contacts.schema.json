{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/brickwalllegend2000/jobbrainmine/brainjob/schemas/contacts.schema.json",
  "title": "Brainjob contacts.json",
  "description": "People associated with a vacancy. job_id must match the parent directory name (enforced by Python).",
  "type": "object",
  "additionalProperties": true,
  "required": ["job_id", "contacts"],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "contacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "role": { "type": ["string", "null"] },
          "organisation": { "type": ["string", "null"] },
          "email": { "type": ["string", "null"] },
          "phone": { "type": ["string", "null"] },
          "linkedin": { "type": ["string", "null"] },
          "relationship": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    }
  }
}
