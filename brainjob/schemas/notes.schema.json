{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/brickwalllegend2000/jobbrainmine/brainjob/schemas/notes.schema.json",
  "title": "Brainjob notes.json",
  "description": "Personal or AI-authored notes. job_id must match the parent directory name (enforced by Python).",
  "type": "object",
  "additionalProperties": true,
  "required": ["job_id", "notes"],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "content", "author"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "created_at": { "type": ["string", "null"] },
          "author": {
            "type": "string",
            "enum": ["user", "ai"]
          },
          "category": {
            "type": ["string", "null"],
            "enum": ["research", "strategy", "interview-prep", "follow-up", "general", null]
          },
          "content": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
